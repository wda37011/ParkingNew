.container {
  min-height: 100vh;
  background: #F5F5F5;
}

/* 顶部 */
.header {
  position: relative;
  height: 360rpx;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(135deg, #4A90E2, #50C878);
  border-radius: 0 0 60rpx 60rpx;
}

.header-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
}

.app-name {
  font-size: 56rpx;
  font-weight: bold;
  color: #FFFFFF;
  letter-spacing: 8rpx;
  margin-bottom: 16rpx;
}

.app-slogan {
  font-size: 26rpx;
  color: rgba(255,255,255,0.9);
}

/* 角色卡片 */
.role-cards {
  margin: -60rpx 30rpx 30rpx;
  position: relative;
  z-index: 2;
}

.role-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 36rpx 30rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 6rpx 24rpx rgba(0,0,0,0.08);
  transition: transform 0.2s;
}

.role-card:active {
  transform: scale(0.98);
}

.card-icon-wrap {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.user-icon-bg { background: linear-gradient(135deg, #E8F4FD, #D0EFFF); }
.worker-icon-bg { background: linear-gradient(135deg, #FFF5E6, #FFE8CC); }
.owner-icon-bg { background: linear-gradient(135deg, #E9F7EF, #D0F0E0); }

.card-icon {
  font-size: 48rpx;
}

.card-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
}

.card-desc {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.4;
}

.card-arrow {
  font-size: 28rpx;
  color: #CCCCCC;
  margin-left: 16rpx;
}

/* 服务保障 */
.guarantee {
  background: #FFFFFF;
  margin: 0 30rpx 40rpx;
  padding: 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
}

.guarantee-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 24rpx;
}

.guarantee-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.guarantee-item:last-child { margin-bottom: 0; }

.guarantee-check {
  color: #50C878;
  font-size: 28rpx;
  font-weight: bold;
  margin-right: 12rpx;
}

.guarantee-text {
  flex: 1;
  font-size: 26rpx;
  color: #666666;
  line-height: 1.5;
}
