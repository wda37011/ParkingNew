.container { display: flex; flex-direction: column; height: 100vh; background: #f5f5f5; }
.scroll { flex: 1; height: 0; padding-bottom: 140rpx; }
.section { background: #fff; margin: 16rpx 30rpx; padding: 24rpx; border-radius: 16rpx; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.04); }
.section-title { font-size: 28rpx; font-weight: bold; color: #333; margin-bottom: 16rpx; padding-bottom: 12rpx; border-bottom: 1rpx solid #f5f5f5; }
.form-row { display: flex; align-items: center; padding: 14rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.form-row:last-child { border-bottom: none; }
.form-label { font-size: 26rpx; color: #333; width: 150rpx; flex-shrink: 0; }
.form-input { flex: 1; font-size: 26rpx; color: #333; }
.form-value { flex: 1; font-size: 26rpx; color: #333; }
.form-value.placeholder { color: #ccc; }
.form-arrow { font-size: 24rpx; color: #ccc; }
.form-unit { font-size: 24rpx; color: #999; margin-left: 8rpx; flex-shrink: 0; }

.photo-area { display: flex; flex-wrap: wrap; gap: 16rpx; }
.photo-item { width: 160rpx; height: 120rpx; position: relative; border-radius: 10rpx; overflow: hidden; }
.photo-img { width: 100%; height: 100%; }
.photo-del { position: absolute; top: 0; right: 0; width: 40rpx; height: 40rpx; background: rgba(0,0,0,0.5); color: #fff; font-size: 24rpx; text-align: center; line-height: 40rpx; border-radius: 0 0 0 10rpx; }
.photo-add { width: 160rpx; height: 120rpx; background: #f8f9fa; border: 2rpx dashed #ccc; border-radius: 10rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; }
.add-icon { font-size: 48rpx; color: #ccc; }
.add-text { font-size: 22rpx; color: #ccc; }

.footer { position: fixed; bottom: 0; left: 0; right: 0; padding: 20rpx 30rpx; padding-bottom: calc(20rpx + env(safe-area-inset-bottom)); background: #fff; box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.06); }
.submit-btn { width: 100%; height: 88rpx; border-radius: 44rpx; font-size: 32rpx; font-weight: bold; color: #fff; background: linear-gradient(135deg, #50C878, #38A55D); }
.submit-btn::after { border: none; }

