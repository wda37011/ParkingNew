.container { display: flex; flex-direction: column; height: 100vh; background: #f5f5f5; }

.income-card { background: linear-gradient(135deg, #50C878, #38A55D); padding: 30rpx; display: flex; justify-content: space-between; align-items: center; }
.income-label { font-size: 24rpx; color: rgba(255,255,255,0.8); display: block; }
.income-val { font-size: 44rpx; font-weight: bold; color: #fff; }
.wallet-link { font-size: 26rpx; color: #fff; background: rgba(255,255,255,0.2); padding: 10rpx 20rpx; border-radius: 20rpx; }

.scroll { flex: 1; height: 0; padding-bottom: 140rpx; }
.empty { padding: 160rpx 0; text-align: center; }
.empty-text { font-size: 28rpx; color: #999; display: block; }
.empty-sub { font-size: 24rpx; color: #ccc; display: block; margin-top: 8rpx; }

.space-card { background: #fff; margin: 16rpx 30rpx; padding: 24rpx; border-radius: 16rpx; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.04); }
.space-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.space-title { font-size: 30rpx; font-weight: bold; color: #333; }
.space-status { font-size: 24rpx; padding: 4rpx 12rpx; border-radius: 10rpx; }
.space-status.on { color: #50C878; background: #E9F7EF; }
.space-status.off { color: #999; background: #f5f5f5; }
.space-body { margin-bottom: 12rpx; }
.space-addr { font-size: 24rpx; color: #666; display: block; margin-bottom: 8rpx; }
.space-price-row { display: flex; align-items: center; margin-bottom: 6rpx; }
.space-price { font-size: 28rpx; font-weight: bold; color: #FF6B6B; margin-right: 16rpx; }
.space-max { font-size: 22rpx; color: #999; }
.space-time { font-size: 22rpx; color: #999; display: block; margin-bottom: 4rpx; }
.space-community { font-size: 22rpx; color: #999; display: block; margin-bottom: 8rpx; }
.photo-row { white-space: nowrap; margin-top: 8rpx; }
.thumb { width: 120rpx; height: 90rpx; border-radius: 8rpx; margin-right: 8rpx; display: inline-block; }

.space-actions { display: flex; gap: 16rpx; border-top: 1rpx solid #f5f5f5; padding-top: 12rpx; }
.s-btn { flex: 1; height: 56rpx; font-size: 24rpx; border-radius: 28rpx; padding: 0; }
.s-btn::after { border: none; }
.s-btn.edit { background: #E8F4FD; color: #4A90E2; }
.s-btn.toggle { background: #FFF5E6; color: #FF9500; }
.s-btn.del { background: #FFF0F0; color: #FF6B6B; }

.footer { position: fixed; bottom: 0; left: 0; right: 0; padding: 20rpx 30rpx; padding-bottom: calc(20rpx + env(safe-area-inset-bottom)); background: #fff; box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.06); }
.add-btn { width: 100%; height: 88rpx; border-radius: 44rpx; font-size: 30rpx; font-weight: bold; color: #fff; background: linear-gradient(135deg, #50C878, #38A55D); }
.add-btn::after { border: none; }

