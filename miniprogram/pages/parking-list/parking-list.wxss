.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

.search-bar {
  padding: 20rpx 30rpx 0;
}

.location-box {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.location-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.location-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.location-title {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 6rpx;
}

.location-address {
  font-size: 28rpx;
  color: #333333;
}

.scroll-view {
  flex: 1;
  height: 0;
  padding-top: 10rpx;
}

.empty {
  padding: 200rpx 60rpx;
  display: flex;
  justify-content: center;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
  text-align: center;
}

.space-item {
  background: #ffffff;
  margin: 20rpx 30rpx;
  padding: 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.space-main {
  margin-bottom: 20rpx;
}

.space-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.space-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.distance {
  font-size: 24rpx;
  color: #999999;
}

.space-address {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 10rpx;
}

.space-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 24rpx;
}

.price {
  font-size: 30rpx;
  font-weight: bold;
  color: #ff6b6b;
}

.status {
  color: #50c878;
}

.space-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #999999;
}

.space-actions {
  display: flex;
  justify-content: flex-end;
}

.reserve-btn {
  height: 70rpx;
  padding: 0 40rpx;
  border-radius: 35rpx;
  font-size: 28rpx;
  background: linear-gradient(135deg, #4a90e2, #50c878);
  color: #ffffff;
}

.reserve-btn::after {
  border: none;
}


