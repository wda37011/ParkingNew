.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

.scroll-view {
  flex: 1;
  height: 0;
}

.header {
  padding: 20rpx 30rpx 0;
}

.primary-btn {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, #4a90e2, #50c878);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.primary-btn::after {
  border: none;
}

.space-item {
  background: #ffffff;
  margin: 20rpx 30rpx;
  padding: 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.space-main {
  margin-bottom: 20rpx;
}

.space-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.space-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.space-status {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 30rpx;
}

.space-status.active {
  background: #e8f4fd;
  color: #4a90e2;
}

.space-status.inactive {
  background: #f5f5f5;
  color: #999999;
}

.space-address {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 10rpx;
}

.space-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 24rpx;
  color: #999999;
}

.price {
  font-size: 28rpx;
  color: #ff6b6b;
  font-weight: bold;
}

.space-actions {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
}

.small-btn {
  height: 60rpx;
  padding: 0 26rpx;
  font-size: 24rpx;
  border-radius: 30rpx;
  background: #f5f5f5;
  color: #666666;
}

.small-btn.secondary {
  background: #e8f4fd;
  color: #4a90e2;
}

.small-btn.danger {
  background: #ffe8e8;
  color: #ff6b6b;
}

.small-btn::after {
  border: none;
}

.empty {
  padding: 200rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 40rpx;
}

/* 弹层 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 99;
}

.modal {
  width: 88%;
  max-width: 680rpx;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
}

.form-item {
  margin-bottom: 20rpx;
}

.label {
  display: block;
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 10rpx;
}

.input {
  width: 100%;
  font-size: 28rpx;
  color: #333333;
  padding: 16rpx 20rpx;
  border-radius: 10rpx;
  background: #f8f9fa;
}

.textarea {
  width: 100%;
  min-height: 160rpx;
  font-size: 28rpx;
  color: #333333;
  padding: 16rpx 20rpx;
  border-radius: 10rpx;
  background: #f8f9fa;
}

.location-view {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 20rpx;
  border-radius: 10rpx;
  background: #f8f9fa;
}

.location-text {
  flex: 1;
  font-size: 26rpx;
  color: #333333;
  margin-right: 10rpx;
}

.location-icon {
  font-size: 36rpx;
}

.modal-footer {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
  margin-top: 20rpx;
}

.footer-btn {
  flex: 1;
  height: 70rpx;
  border-radius: 35rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.footer-btn.primary {
  background: linear-gradient(135deg, #4a90e2, #50c878);
  color: #ffffff;
}

.footer-btn.secondary {
  background: #f5f5f5;
  color: #666666;
}

.footer-btn::after {
  border: none;
}


