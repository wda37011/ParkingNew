.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #F5F5F5;
}

.scroll-view {
  flex: 1;
  height: 0;
  padding-bottom: 200rpx;
}

/* ===== 通用卡片 ===== */
.section {
  background: #FFFFFF;
  margin: 20rpx 30rpx;
  padding: 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #F5F5F5;
}

/* ===== 信息行 ===== */
.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15rpx 0;
}

.info-label {
  font-size: 28rpx;
  color: #666666;
  flex-shrink: 0;
}

.info-value {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  text-align: right;
  max-width: 60%;
  word-break: break-all;
}

.info-value.address {
  font-size: 24rpx;
  color: #666666;
}

.info-value.price {
  font-size: 36rpx;
  font-weight: bold;
  color: #FF6B6B;
}

/* ===== 费用明细 ===== */
.fee-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 0;
}

.fee-row.sub {
  padding: 10rpx 0;
}

.fee-row.sub .fee-label,
.fee-row.sub .fee-value {
  font-size: 24rpx;
  color: #999999;
}

.fee-label {
  font-size: 28rpx;
  color: #666666;
}

.fee-value {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.fee-divider {
  height: 2rpx;
  background: #F0F0F0;
  margin: 10rpx 0;
}

.fee-total-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0 4rpx;
}

.fee-total-label {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
}

.fee-total-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #FF6B6B;
}

/* ===== 支付方式 ===== */
.payment-methods {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.payment-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: #F8F9FA;
  border-radius: 10rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.payment-item.active {
  background: #E8F4FD;
  border-color: #4A90E2;
}

.payment-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.payment-name {
  flex: 1;
  font-size: 32rpx;
  color: #333333;
  font-weight: 500;
}

.payment-check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #4A90E2;
  display: flex;
  align-items: center;
  justify-content: center;
}

.check-icon {
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: bold;
}

/* ===== 支付说明 ===== */
.notice-section {
  background: #FFF9E6;
  margin: 20rpx 30rpx;
  padding: 30rpx;
  border-radius: 20rpx;
  border-left: 6rpx solid #FF9500;
}

.notice-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #FF9500;
  margin-bottom: 20rpx;
}

.notice-item {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.6;
  margin-bottom: 10rpx;
}

/* ===== 底部支付栏 ===== */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.price-summary {
  flex: 1;
  display: flex;
  align-items: baseline;
}

.price-label {
  font-size: 28rpx;
  color: #666666;
}

.price-total {
  font-size: 40rpx;
  font-weight: bold;
  color: #FF6B6B;
  margin-left: 10rpx;
}

.pay-btn {
  width: 260rpx;
  height: 84rpx;
  background: linear-gradient(135deg, #4A90E2, #50C878);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 20rpx;
}

.pay-btn::after {
  border: none;
}

.pay-btn[disabled] {
  background: #CCCCCC;
  color: #999999;
}
