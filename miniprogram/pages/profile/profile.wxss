.container { height: 100vh; display: flex; flex-direction: column; background: #F5F5F5; }
.scroll-view { flex: 1; height: 0; }

.user-section { background: linear-gradient(135deg, #4A90E2, #50C878); padding: 60rpx 30rpx 40rpx; color: #fff; }
.user-info { display: flex; align-items: center; }
.user-avatar { width: 120rpx; height: 120rpx; border-radius: 50%; border: 4rpx solid rgba(255,255,255,0.3); margin-right: 24rpx; }
.user-detail { flex: 1; }
.user-name { font-size: 36rpx; font-weight: bold; display: block; margin-bottom: 8rpx; }
.user-tags { display: flex; gap: 12rpx; flex-wrap: wrap; }
.tag { font-size: 22rpx; padding: 4rpx 12rpx; border-radius: 10rpx; background: rgba(255,255,255,0.2); color: #fff; }
.worker-tag { background: rgba(255,165,0,0.3); }
.owner-tag { background: rgba(80,200,120,0.3); }
.login-prompt { display: flex; justify-content: center; padding: 40rpx 0; }
.login-btn { width: 200rpx; height: 80rpx; background: rgba(255,255,255,0.2); color: #fff; font-size: 32rpx; border-radius: 40rpx; border: 2rpx solid rgba(255,255,255,0.3); }
.login-btn::after { border: none; }

.wallet-card { background: #fff; margin: -20rpx 30rpx 20rpx; padding: 30rpx; border-radius: 20rpx; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1); display: flex; align-items: center; }
.wallet-left { flex: 1; }
.wallet-label { font-size: 28rpx; color: #333; display: block; margin-bottom: 8rpx; }
.wallet-balance { font-size: 40rpx; font-weight: bold; color: #FF6B6B; }
.wallet-arrow { font-size: 28rpx; color: #ccc; }

.menu-section { background: #fff; margin: 0 30rpx 24rpx; border-radius: 20rpx; overflow: hidden; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04); }
.menu-item { display: flex; align-items: center; padding: 28rpx 30rpx; border-bottom: 1rpx solid #f5f5f5; }
.menu-item:last-child { border-bottom: none; }
.menu-icon { font-size: 36rpx; margin-right: 20rpx; }
.menu-text { flex: 1; font-size: 30rpx; color: #333; }
.menu-arrow { font-size: 24rpx; color: #ccc; }

.guarantee-section { background: #E8F4FD; margin: 0 30rpx 40rpx; padding: 24rpx; border-radius: 16rpx; border-left: 6rpx solid #4A90E2; }
.guarantee-title { font-size: 28rpx; font-weight: bold; color: #4A90E2; margin-bottom: 16rpx; }
.guarantee-item { display: flex; align-items: flex-start; margin-bottom: 12rpx; }
.guarantee-item:last-child { margin-bottom: 0; }
.guarantee-icon { color: #50C878; font-size: 26rpx; font-weight: bold; margin-right: 12rpx; }
.guarantee-text { flex: 1; font-size: 24rpx; color: #666; line-height: 1.5; }
