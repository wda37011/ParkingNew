<view class="container">
  <scroll-view class="scroll-view" scroll-y>
    <!-- 订单信息 -->
    <view class="section">
      <view class="section-title">订单信息</view>
      <view class="info-item">
        <text class="info-label">订单号</text>
        <text class="info-value">{{order.id}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">车牌号</text>
        <text class="info-value">{{order.carNumber}}</text>
      </view>
    </view>

    <!-- 违章信息 -->
    <view class="section">
      <view class="section-title">违章信息</view>
      
      <view class="form-item">
        <text class="label">违章时间</text>
        <picker mode="date" value="{{violationTime}}" bindchange="onViolationTimeChange">
          <view class="picker-view">
            <text class="picker-text">{{violationTime || '请选择违章时间'}}</text>
            <text class="picker-arrow">></text>
          </view>
        </picker>
      </view>

      <view class="form-item">
        <text class="label">违章类型</text>
        <picker mode="selector" range="{{violationTypes}}" value="{{violationTypeIndex}}" bindchange="onViolationTypeChange">
          <view class="picker-view">
            <text class="picker-text">{{violationType || '请选择违章类型'}}</text>
            <text class="picker-arrow">></text>
          </view>
        </picker>
      </view>

      <view class="form-item">
        <text class="label">罚款金额</text>
        <input 
          class="input" 
          type="digit" 
          placeholder="请输入罚款金额（元）" 
          value="{{fine}}" 
          bindinput="onFineInput" 
        />
      </view>
    </view>

    <!-- 证据上传 -->
    <view class="section">
      <view class="section-title">上传证据</view>
      <view class="notice-text">请上传违章照片作为证据（最多3张）</view>
      <view class="evidence-list">
        <view wx:for="{{evidence}}" wx:key="index" class="evidence-item">
          <image 
            class="evidence-image" 
            src="{{item}}" 
            mode="aspectFill"
            bindtap="previewEvidence"
            data-index="{{index}}"
          ></image>
          <view class="delete-btn" bindtap="deleteEvidence" data-index="{{index}}">×</view>
        </view>
        <view wx:if="{{evidence.length < 3}}" class="evidence-item upload-btn" bindtap="uploadEvidence">
          <text class="upload-icon">+</text>
          <text class="upload-text">上传照片</text>
        </view>
      </view>
    </view>

    <!-- 保障说明 -->
    <view class="guarantee-section">
      <view class="guarantee-title">保障说明</view>
      <view class="guarantee-text">
        • 车辆在代停车期间发生违章，30日内由小哥全额赔偿<br/>
        • 请确保违章时间在订单服务期间内<br/>
        • 请上传清晰的违章照片作为证据
      </view>
    </view>
  </scroll-view>

  <!-- 底部提交按钮 -->
  <view class="footer">
    <button class="submit-btn" bindtap="submitViolation">提交上报</button>
  </view>
</view>

