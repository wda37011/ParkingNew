.container { display: flex; flex-direction: column; height: 100vh; background: #f5f5f5; }

.header { background: linear-gradient(135deg, #4A90E2, #50C878); padding: 40rpx 30rpx; display: flex; justify-content: space-between; align-items: center; }
.hi-text { font-size: 34rpx; font-weight: bold; color: #fff; display: block; }
.sub-text { font-size: 24rpx; color: rgba(255,255,255,0.8); margin-top: 6rpx; display: block; }
.wallet-text { font-size: 28rpx; color: #fff; background: rgba(255,255,255,0.2); padding: 12rpx 24rpx; border-radius: 30rpx; }

.sort-bar { display: flex; background: #fff; padding: 16rpx 30rpx; }
.sort-item { flex: 1; text-align: center; font-size: 28rpx; color: #666; padding: 12rpx 0; border-radius: 30rpx; }
.sort-item.active { color: #4A90E2; font-weight: bold; background: #E8F4FD; }

.order-list { flex: 1; height: 0; padding: 10rpx 0; }
.empty { padding: 200rpx 0; text-align: center; }
.empty-text { font-size: 28rpx; color: #999; }

.order-card { background: #fff; margin: 16rpx 30rpx; padding: 24rpx; border-radius: 20rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05); }
.card-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.card-price { font-size: 40rpx; font-weight: bold; color: #FF6B6B; }
.card-status { font-size: 24rpx; color: #999; padding: 6rpx 16rpx; background: #f5f5f5; border-radius: 20rpx; }
.card-status.mine { color: #4A90E2; background: #E8F4FD; }
.card-info { margin-bottom: 12rpx; }
.info-row { display: flex; align-items: center; margin-bottom: 8rpx; }
.info-icon { font-size: 24rpx; margin-right: 8rpx; }
.info-text { font-size: 26rpx; color: #333; }
.card-car { margin-top: 8rpx; }
.car-num { font-size: 28rpx; font-weight: bold; color: #4A90E2; background: #E8F4FD; padding: 6rpx 16rpx; border-radius: 8rpx; }

