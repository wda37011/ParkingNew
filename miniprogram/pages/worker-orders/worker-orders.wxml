<view class="container">
  <!-- 标签切换 -->
  <view class="filter-tabs">
    <view 
      class="tab-item {{currentTab === 'available' ? 'active' : ''}}"
      bindtap="switchTab"
      data-tab="available"
    >
      可接单
    </view>
    <view 
      class="tab-item {{currentTab === 'my' ? 'active' : ''}}"
      bindtap="switchTab"
      data-tab="my"
    >
      我的订单
    </view>
  </view>

  <!-- 订单列表 -->
  <scroll-view 
    class="order-list" 
    scroll-y 
    refresher-enabled="{{true}}" 
    refresher-triggered="{{refreshing}}" 
    bindrefresherrefresh="onRefresh"
  >
    <!-- 可接单列表 -->
    <view wx:if="{{currentTab === 'available'}}">
      <view wx:if="{{availableOrders.length === 0}}" class="empty-state">
        <text class="empty-text">暂无可接订单</text>
      </view>

      <view wx:for="{{availableOrders}}" wx:key="id" class="order-item">
        <view class="order-header">
          <view class="order-info">
            <text class="order-id">订单号：{{item.id}}</text>
            <text class="order-time">{{item.createTime}}</text>
          </view>
          <view class="order-status" style="color: {{item.statusColor}}">
            {{item.statusText}}
          </view>
        </view>

        <view class="order-content">
          <view class="order-car">
            <text class="car-number">{{item.carNumber}}</text>
            <text wx:if="{{item.carBrand}}" class="car-info">{{item.carBrand}} {{item.carColor}}</text>
          </view>

          <view class="order-location">
            <view class="location-row">
              <text class="location-label">取车：</text>
              <text class="location-value">{{item.pickLocation.address}}</text>
            </view>
            <view class="location-row">
              <text class="location-label">还车：</text>
              <text class="location-value">{{item.returnLocation.address}}</text>
            </view>
          </view>

          <view class="order-time-info">
            <text class="time-label">取车时间：</text>
            <text class="time-value">{{item.pickTime}}</text>
          </view>
        </view>

        <view class="order-footer">
          <view class="order-price">
            <text class="price-label">服务费用：</text>
            <text class="price-value">¥{{item.price}}</text>
          </view>
          <button class="accept-btn" bindtap="acceptOrder" data-id="{{item.id}}">
            接单
          </button>
        </view>
      </view>
    </view>

    <!-- 我的订单列表 -->
    <view wx:if="{{currentTab === 'my'}}">
      <view wx:if="{{myOrders.length === 0}}" class="empty-state">
        <text class="empty-text">暂无订单</text>
      </view>

      <view wx:for="{{myOrders}}" wx:key="id" class="order-item">
        <view class="order-header">
          <view class="order-info">
            <text class="order-id">订单号：{{item.id}}</text>
            <text class="order-time">{{item.createTime}}</text>
          </view>
          <view class="order-status" style="color: {{item.statusColor}}">
            {{item.statusText}}
          </view>
        </view>

        <view class="order-content">
          <view class="order-car">
            <text class="car-number">{{item.carNumber}}</text>
            <text wx:if="{{item.carBrand}}" class="car-info">{{item.carBrand}} {{item.carColor}}</text>
          </view>

          <view class="order-location">
            <view class="location-row">
              <text class="location-label">取车：</text>
              <text class="location-value">{{item.pickLocation.address}}</text>
            </view>
            <view class="location-row">
              <text class="location-label">还车：</text>
              <text class="location-value">{{item.returnLocation.address}}</text>
            </view>
          </view>
        </view>

        <view class="order-footer">
          <view class="order-price">
            <text class="price-label">服务费用：</text>
            <text class="price-value">¥{{item.price}}</text>
          </view>
          <view class="order-actions">
            <!-- 取车阶段 -->
            <button 
              wx:if="{{item.status === 'accepted'}}" 
              class="action-btn status-btn"
              bindtap="startPick"
              data-id="{{item.id}}"
            >
              开始取车并导航
            </button>
            <button 
              wx:if="{{item.status === 'picking'}}" 
              class="action-btn status-btn"
              bindtap="arrivePick"
              data-id="{{item.id}}"
            >
              已到达取车点
            </button>
            <button 
              wx:if="{{item.status === 'picking'}}" 
              class="action-btn status-btn"
              bindtap="updateOrderStatus"
              data-order-id="{{item.id}}"
              data-status="parked"
            >
              确认停车
            </button>

            <!-- 还车阶段 -->
            <button 
              wx:if="{{item.status === 'parked'}}" 
              class="action-btn status-btn"
              bindtap="startReturn"
              data-id="{{item.id}}"
            >
              开始还车并导航
            </button>
            <button 
              wx:if="{{item.status === 'returning'}}" 
              class="action-btn status-btn"
              bindtap="arriveReturn"
              data-id="{{item.id}}"
            >
              已到达还车点
            </button>

            <button 
              class="action-btn view-btn"
              bindtap="viewOrderDetail"
              data-id="{{item.id}}"
            >
              查看详情
            </button>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>
</view>

