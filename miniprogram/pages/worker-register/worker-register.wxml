<view class="container">
  <scroll-view class="scroll" scroll-y>
    <view class="section">
      <view class="section-title">基本信息</view>
      <view class="form-row">
        <text class="form-label">姓名</text>
        <input class="form-input" placeholder="请输入真实姓名" value="{{name}}" bindinput="onNameInput" />
      </view>
      <view class="form-row">
        <text class="form-label">联系电话</text>
        <input class="form-input" type="number" placeholder="请输入手机号" value="{{phone}}" bindinput="onPhoneInput" />
      </view>
      <view class="form-row">
        <text class="form-label">身份证号</text>
        <input class="form-input" placeholder="请输入身份证号码" value="{{idNumber}}" bindinput="onIdInput" />
      </view>
    </view>

    <view class="section">
      <view class="section-title">驾驶证照片</view>
      <view class="photo-area" bindtap="chooseLicense">
        <image wx:if="{{driverLicensePhoto}}" class="license-photo" src="{{driverLicensePhoto}}" mode="aspectFit" />
        <view wx:else class="photo-placeholder">
          <text class="photo-icon">📷</text>
          <text class="photo-text">点击上传驾驶证</text>
        </view>
      </view>
    </view>

    <view class="notice">
      <text class="notice-text">• 请确保信息真实有效</text>
      <text class="notice-text">• 注册后可接取代停车订单</text>
      <text class="notice-text">• 代停期间车辆违章需承担赔偿责任</text>
    </view>
  </scroll-view>

  <view class="footer">
    <button class="submit-btn" bindtap="submit">提交注册</button>
  </view>
</view>

